APP_NAME=smart-customer-service
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/customer_service
REDIS_URL=redis://redis:6379/0

TRACKER_STORE=memory
VECTOR_STORE=memory

LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=1024

RERANK_PROVIDER=mock
RERANK_MODEL=
RERANK_BASE_URL=
RERANK_API_KEY=

BUSINESS_PROVIDER=mock
BUSINESS_API_BASE_URL=
BUSINESS_API_KEY=
BUSINESS_API_TIMEOUT=15

HANDOFF_PROVIDER=mock
HANDOFF_WEBHOOK_URL=
HANDOFF_API_KEY=

NLG_REPHRASE_ENABLED=false
NLG_REPHRASE_STYLE=professional

CHUNK_SIZE=600
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=10
RERANK_TOP_N=5
RETRIEVAL_SCORE_THRESHOLD=0.35

MAX_ACTIONS_PER_TURN=10
MAX_HISTORY_MESSAGES=20
SESSION_TTL_SECONDS=86400

